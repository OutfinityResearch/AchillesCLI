{
    "name": "@outfinityresearch/achilles-cli",
    "version": "0.1.0",
    "description": "CLI agent for managing, generating, and testing skill definition files in skills directories.",
    "license": "MIT",
    "type": "module",
    "main": "src/index.mjs",
    "bin": {
        "achilles-cli": "./bin/achilles-cli"
    },
    "exports": {
        ".": "./src/index.mjs",
        "./AchillesCli": "./src/AchillesCli.mjs"
    },
    "files": [
        "src",
        "bin",
        "scripts"
    ],
    "scripts": {
        "test": "node --test tests/*.test.mjs",
        "test:all": "node tests/run-all.mjs",
        "postinstall": "node scripts/postinstall.mjs"
    },
    "dependencies": {
        "mcp-sdk": "github:PloinkyRepos/MCPSDK",
        "flexsearch": "github:PloinkyRepos/flexsearch#main"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/outfinityresearch/achilles-cli.git"
    },
    "keywords": [
        "achilles",
        "achilles-cli",
        "agent",
        "cli"
    ]
}
